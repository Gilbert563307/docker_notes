# Stage 1: Build Stage
FROM node:18.18.2-bullseye-slim AS builder

WORKDIR /app

# Install dependencies and build the Vite app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Production Stage
FROM node:18.18.2-bullseye-slim

WORKDIR /app

# Install `serve` for serving the static files
RUN npm install -g serve

# Copy only the built files from the build stage
COPY --from=builder /app/dist /app/dist

# Expose the port Vite serves on (if 5173 is the port you want)
EXPOSE 5173

# Start the app using the built files
CMD ["serve", "-s", "dist", "-l", "5173"]
